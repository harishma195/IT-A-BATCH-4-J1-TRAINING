// 1.Sum of Array Elements
import java.util.Scanner;
public class Main{
	public static void main(String[] args){
	int sum = 0; 
	Scanner sc = new Scanner(System.in);
	int n = sc.nextInt();
	int b[] = new int[n];
	for(int i =0;i<n;i++){
		b[i] = sc.nextInt();
		sum+=b[i];
		}
	System.out.println(sum);
	}
}
